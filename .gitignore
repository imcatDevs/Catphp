# ─── Storage (런타임 데이터) ───
storage/app/*
storage/cache/*
storage/logs/*
storage/firewall/*
storage/rate/*
!storage/**/.gitkeep

# ─── 업로드 ───
Public/uploads/*
!Public/uploads/.gitkeep

# ─── 설정 백업 ───
config/*.bak.*

# ─── 릴리스 아티팩트 ───
releases/*.zip
releases/*.tar.gz

# ─── 의존성 ───
vendor/
composer.lock
node_modules/

# ─── 환경 설정 (비밀키 포함) ───
.env
.env.*
!.env.example

# ─── IDE ───
.idea/
.vscode/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# ─── OS ───
Thumbs.db
Desktop.ini
.DS_Store

# ─── 로그 ───
*.log
npm-debug.log*

# ─── PHP / 테스트 ───
.phpunit.cache/
.php-cs-fixer.cache

# ─── Windsurf (개인) ───
.windsurf/

# ─── 원격 배포 SSH 키 (커밋 금지) ───
RemoteSSh/
*.pem
*_id_ed25519
*_id_rsa
!*.pub

# ─── 배포 아티팩트 ───
*.tar.gz
catphp-deploy*
